{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "public/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/", "dest": "/public/index.php" },
    { "src": "/login", "dest": "/public/login.php" },
    { "src": "/logout", "dest": "/public/logout.php" },
    { "src": "/dashboard", "dest": "/public/dashboard.php" },
    { "src": "/register", "dest": "/public/register.php" },
    { "src": "/test-ai", "dest": "/public/test-ai.php" },
    { "src": "/ai-api", "dest": "/api/ai-api.php" },
    { "src": "/firebase-auth", "dest": "/api/firebase-auth.php" },
    { "src": "/qwen-chat", "dest": "/api/qwen-chat.php" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}
